# ── Cấu hình RAG Service ──────────────────────────────────────────────
# Khi chạy bằng Docker Compose: compose ĐÃ set sẵn các biến này, KHÔNG cần file .env.
# File này dành cho chạy LOCAL (không Docker): copy thành .env rồi chỉnh nếu cần.

# MongoDB. Local: localhost:27017. (Trong Docker compose dùng: mongodb://mongo:27017/rag_db)
MONGODB_URI=mongodb://localhost:27017/rag_db

# Ollama server. Local: localhost. (Trong Docker compose dùng: http://ollama:11434)
OLLAMA_URL=http://localhost:11434

# LLM fine-tune (đã push GGUF lên HuggingFace).
# Nếu repo HF có nhiều bản quant, đổi tag cho khớp, vd ...:Q4_K_M
FINE_TUNED_OLLAMA_LLM_MODEL=hf.co/Tobi2904/qwen-finetuned-dpo-gguf:latest

# Embeddings: Ollama phục vụ bge-m3  ->  cần chạy: ollama pull bge-m3
OLLAMA_EMBED_MODEL=bge-m3
