# ── Cấu hình RAG Service ──────────────────────────────────────────────
# Khi chạy bằng Docker Compose: compose ĐÃ set sẵn các biến này, KHÔNG cần file .env.
# File này dành cho chạy LOCAL (không Docker): copy thành .env rồi chỉnh nếu cần.

# MongoDB connection URI (Mặc định chạy local: mongodb://localhost:27017/rag_db)
MONGODB_URI=mongodb://localhost:27017/rag_db

# Địa chỉ Ollama server (Mặc định local: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Mô hình LLM fine-tune chạy qua Ollama (Được kéo trực tiếp từ HuggingFace)
FINE_TUNED_OLLAMA_LLM_MODEL=hf.co/Tobi2904/qwen-finetuned-dpo-gguf:latest

# Mô hình Embedding chạy qua Ollama (Cần chạy lệnh: ollama pull bge-m3)
OLLAMA_EMBED_MODEL=bge-m3

# Kích thước tối đa của mỗi chunk văn bản thường (Số ký tự, khuyến nghị: 600)
CHUNK_SIZE_PROSE=

# Độ chồng lấn giữa các chunk liền kề để tránh mất ngữ cảnh ở biên (Số ký tự, khuyến nghị: 100)
CHUNK_OVERLAP=

# Số lượng chunks liên quan nhất trả về khi truy vấn retrieval (Khuyến nghị: 5)
TOP_K=

# Số lượng chunks tạo embedding cùng lúc trong một batch để tối ưu hóa hiệu năng (Khuyến nghị: 32)
EMBED_BATCH_SIZE=

# Hugging Face Access Token - Dùng để tải mô hình/tập dữ liệu riêng tư hoặc push model đã train lên HF Hub
HF_TOKEN=

# API Key của Google Gemini dùng để xác thực các cuộc gọi API (ví dụ: Gemini OCR)
GEMINI_API_KEY=

# Tên mô hình Gemini được dùng để thực hiện OCR trang sách scan (Mặc định: gemini-3.1-flash-lite-preview)
GEMINI_OCR_MODEL=

# Số lượng trang PDF được gom nhóm gửi lên Gemini OCR cùng lúc trong mỗi batch (Khuyến nghị: 5)
OCR_PAGES_PER_BATCH=

# Độ phân giải (DPI) khi chuyển trang PDF sang ảnh để đưa vào OCR (Khuyến nghị: 150)
OCR_DPI=

# Thời gian nghỉ (giây) giữa các batch gửi lên Gemini để tránh lỗi quá giới hạn Request (Rate Limit) (Khuyến nghị: 4)
OCR_DELAY_BETWEEN_BATCHES=

